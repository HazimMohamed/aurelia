[Unit]
Description=Aurelia FastAPI Server
After=network.target

[Service]
User=zuzu
Group=zuzu
WorkingDirectory=/home/zuzu/Code/aurelia/src
ExecStart=/home/zuzu/.local/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
EnvironmentFile=/home/zuzu/Code/aurelia/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=aurelia-server

[Install]
WantedBy=multi-user.target
