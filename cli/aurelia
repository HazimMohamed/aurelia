# ── Low-level socket helper ───────────────────────────────────────────────────

def _socket_call(request: dict) -> tuple[bool, object]:
    """Send a JSON request to the runtime socket and return (ok, data)."""
    import uuid
    if "id" not in request:
        request = {**request, "id": str(uuid.uuid4())}
    payload = json.dumps(request).encode("utf-8") + b"\n"
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
            sock.settimeout(300.0)
            sock.connect(str(SOCKET_PATH))
            sock.sendall(payload)
            buf = b""
            while b"\n" not in buf:
                chunk = sock.recv(65536)
                if not chunk:
                    return False, "Connection closed unexpectedly"
                buf += chunk
            line, _ = buf.split(b"\n", 1)
            response = json.loads(line.decode("utf-8"))
    except (FileNotFoundError, ConnectionRefusedError):
        return False, "socket_unreachable"
    except json.JSONDecodeError as e:
        return False, f"Malformed response: {e}"
    except OSError as e:
        return False, str(e)

    if response.get("status") == "error":
        return False, response.get("message", "Unknown error")
    return True, response.get("data")


def _require_runtime() -> bool:
    """Check runtime is up; print error and return False if not."""
    ok, _ = _socket_call({"type": "get_health"})
    if not ok:
        console.print()
        console.print("  [red]✗ Runtime daemon is not running[/red]")
        console.print("  [dim]Start it with: aurelia start[/dim]")
        console.print()
    return ok


def _runtime_ok() -> bool:
    ok, _ = _socket_call({"type": "get_health"})
    return ok


def _http_ok() -> bool:
    try:
        import urllib.request
        with urllib.request.urlopen("http://localhost:8000/health", timeout=2) as resp:
            return resp.status == 200
    except Exception:
        return False


def _read_pid(name: str) -> int | None:
    pid_file = PIDS_DIR / f"{name}.pid"
    if pid_file.exists():
        try:
            return int(pid_file.read_text().strip())
        except (ValueError, OSError):
            return None
    return None


def _discover_http_pid() -> int | None:
    """Find the PID of the process listening on port 8000 via /proc, and cache it."""
    try:
        result = subprocess.run(
            ["ss", "-tlnp", "sport", "=", ":8000"],
            capture_output=True, text=True,
        )
        for line in result.stdout.splitlines():
            if ":8000" in line and "pid=" in line:
                import re
                m = re.search(r"pid=(\d+)", line)
                if m:
                    pid = int(m.group(1))
                    try:
                        pid_file = PIDS_DIR / "http.pid"
                        pid_file.write_text(str(pid))
                    except OSError:
                        pass
                    return pid
    except Exception:
        pass
    return None


def _pid_alive(pid: int | None) -> bool:
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def _count_pending() -> int:
    if not SCHEDULER_PENDING.exists():
        return 0
    return sum(1 for f in SCHEDULER_PENDING.iterdir() if f.suffix == ".json")


def _load_env() -> dict:
    """Load .env from project root into a dict, merged with os.environ."""
    env = os.environ.copy()
    env_path = PROJECT_ROOT / ".env"
    if env_path.exists():
        try:
            from dotenv import dotenv_values
            env.update(dotenv_values(str(env_path)))
        except ImportError:
            for line in env_path.read_text().splitlines():
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, _, v = line.partition("=")
                    env[k.strip()] = v.strip().strip('"').strip("'")
    return env


# ── Formatting helpers ─────────────────────────────────────────────────────────

def _budget_bar(remaining: int | None, total: int | None) -> Text:
    """Return a 10-char block bar + remaining tokens display."""
    if remaining is None or total is None:
        return Text("—", style="dim")

    ratio = remaining / total if total > 0 else 0

    filled = round(ratio * 10)
    filled = max(0, min(10, filled))
    empty = 10 - filled
    bar = "▓" * filled + "░" * empty

    if ratio > 0.5:
        color = "green"
    elif ratio > 0.2:
        color = "yellow"
    else:
        color = "red"

    def _fmt(n: int) -> str:
        if n >= 1_000_000:
            return f"{n / 1_000_000:.1f}M"
        if n >= 1_000:
            return f"{n // 1_000}k"
        return str(n)

    return Text(f"{bar} {_fmt(remaining)}", style=color)


def _status_dot(status: str) -> Text:
    match status:
        case "active":
            return Text("● active", style="bold green")
        case "sleeping" | "sleep":
            return Text("○ sleep", style="dim white")
        case "budget_paused":
            return Text("⊘ paused", style="bold red")
        case "error":
            return Text("✗ error", style="bold red")
        case _:
            return Text(f"? {status}", style="dim")


def _relative_time(ts_str: str | None) -> str:
    """Convert ISO timestamp to relative human string like '2m ago'."""
    if not ts_str:
        return "never"
    try:
        # Try with and without timezone suffix
        for fmt in ("%Y-%m-%dT%H:%M:%S.%f%z", "%Y-%m-%dT%H:%M:%S%z",
                    "%Y-%m-%dT%H:%M:%S.%f", "%Y-%m-%dT%H:%M:%S"):
            try:
                dt = datetime.strptime(ts_str, fmt)
                break
            except ValueError:
                continue
        else:
            return ts_str[:16]

        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        now = datetime.now(timezone.utc)
        diff = int((now - dt).total_seconds())

        if diff < 60:
            return f"{diff}s ago"
        if diff < 3600:
            return f"{diff // 60}m ago"
        if diff < 86400:
            return f"{diff // 3600}h ago"
        return f"{diff // 86400}d ago"
    except Exception:
        return ts_str[:16] if ts_str else "never"


def _now_str() -> str:
    return datetime.now().strftime("%A %-d %b %Y  %H:%M")


# ── Status dashboard renderables ───────────────────────────────────────────────

def _build_header() -> Panel:
    title_line = Text("\u2726  AURELIA — THE PLANE  \u2726", style="bold white", justify="center")
    time_line = Text(_now_str(), style="dim white", justify="center")
    content = Text.assemble(title_line, "\n", time_line)
    return Panel(content, box=box.DOUBLE, style="bold", expand=True)


def _build_agents_table(agents: list[dict]) -> Table:
    table = Table(
        box=box.SIMPLE_HEAVY,
        show_header=True,
        header_style="bold dim white",
        expand=False,
        padding=(0, 1),
    )
    table.add_column("Agent", style="white", min_width=10)
    table.add_column("Status", min_width=14)
    table.add_column("Manas", justify="right", min_width=8)
    table.add_column("Incarnation", min_width=26)
    table.add_column("Cycle", justify="right", min_width=6)
    table.add_column("Budget", min_width=18)
    table.add_column("Last Active", min_width=12)

    for a in agents:
        status = a.get("status", "unknown")
        incarnation = a.get("incarnation") or "—"
        cycle = str(a.get("cycle") or "—")
        last_active = _relative_time(a.get("last_active"))
        budget_text = _budget_bar(a.get("budget_remaining"), a.get("weekly_budget"))
        status_text = _status_dot(status)
        row_style = "" if status == "active" else "dim"

        pid_path = Path("/var/aurelia/run") / a["name"] / "manas.pid"
        try:
            manas_pid = pid_path.read_text().strip() if pid_path.exists() else "—"
        except OSError:
            manas_pid = "—"

        table.add_row(
            Text(a["name"], style=row_style),
            status_text,
            Text(manas_pid, style="green" if manas_pid != "—" else "dim"),
            Text(incarnation, style=row_style),
            Text(cycle, style=row_style),
            budget_text,
            Text(last_active, style=row_style),
        )

    return table


def _build_system_table() -> Table:
    runtime_pid = _read_pid("runtime")
    runtime_up = _runtime_ok()
    http_up = _http_ok()
    http_pid = _read_pid("http") or (http_up and _discover_http_pid()) or None

    table = Table(
        box=box.SIMPLE_HEAVY,
        show_header=True,
        header_style="bold dim white",
        expand=False,
        padding=(0, 1),
    )
    table.add_column("Process", min_width=20)
    table.add_column("Status", min_width=10)
    table.add_column("PID", min_width=8)

    def _row(name: str, up: bool, pid: int | None) -> None:
        status_text = Text("● up", style="bold green") if up else Text("○ down", style="bold red")
        pid_str = str(pid) if pid else "—"
        table.add_row(name, status_text, pid_str)

    _row("runtime daemon", runtime_up, runtime_pid)
    _row("http transport", http_up, http_pid)
    return table


def _build_status_layout(agents: list[dict]) -> object:
    from rich.console import Group as RichGroup

    header = _build_header()
    agents_label = Text("\n  AGENTS", style="bold white")
    agents_table = _build_agents_table(agents)
    system_label = Text("\n  SYSTEM", style="bold white")
    system_table = _build_system_table()

    pending = _count_pending()
    # dashboard notifications — peek at queue dir
    dash_queue = Path("/var/aurelia/dashboard/queue")
    dash_pending = len(list(dash_queue.glob("*.json"))) if dash_queue.exists() else 0

    footer = Text(
        f"\n  {pending} items pending in scheduler   ·   {dash_pending} dashboard notifications"
        "\n  Refreshing every 3s — press Ctrl-C to exit",
        style="dim",
    )

    return RichGroup(header, agents_label, agents_table, system_label, system_table, footer)


