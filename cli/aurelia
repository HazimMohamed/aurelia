def _manas_socket(name: str) -> Path:
    return Path("/var/aurelia/run") / name / "manas.sock"


def _manas_alive(name: str) -> bool:
    """Return True if this agent's Manas process is live."""
    sock_path = _manas_socket(name)
    if not sock_path.exists():
        return False
    try:
        import json as _json
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(1.0)
            s.connect(str(sock_path))
            s.sendall(_json.dumps({"type": "ping"}).encode() + b"\n")
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(256)
                if not chunk:
                    return False
                buf += chunk
        return True
    except (OSError, socket.timeout):
        return False


@cmd_agent.command("start")
@click.argument("name")
def cmd_agent_start(name: str) -> None:
    """Launch (or restart) a Manas process for this agent."""
    console.print(f"\n  [bold]Starting Manas: {escape(name)}[/bold]\n")

    _require_root()

    if _manas_alive(name):
        console.print(f"  [dim]Manas already running[/dim]\n")
        return

    run_dir = Path("/var/aurelia/run") / name
    run_dir.mkdir(parents=True, exist_ok=True)
    log_path = run_dir / "manas.log"

    env = _load_env()
    env["PYTHONPATH"] = str(PROJECT_ROOT)
    try:
        with log_path.open("w") as log_f:
            proc = subprocess.Popen(
                ["sudo", "-E", "-u", name, "/opt/aurelia/bin/manas-launch", name],
                cwd=str(PROJECT_ROOT),
                env=env,
                stdout=log_f,
                stderr=log_f,
                start_new_session=True,
            )
        # Wait briefly for Manas to bind its socket (up to 3s)
        for _ in range(15):
            time.sleep(0.2)
            if _manas_alive(name):
                console.print(f"  [green]✓ Manas started (sudo pid={proc.pid})[/green]\n")
                return
        # Socket never appeared — show whatever Manas printed
        console.print(f"  [yellow]~ Manas launched but socket not yet live (pid={proc.pid})[/yellow]")
        try:
            output = log_path.read_text().strip()
            if output:
                console.print(f"\n  [dim]manas.log:[/dim]")
                for line in output.splitlines():
                    console.print(f"  [red]{escape(line)}[/red]")
        except OSError:
            pass
        console.print()
    except Exception as e:
        console.print(f"  [red]✗ Failed to start Manas:[/red] {e}\n")


@cmd_agent.command("stop")
@click.argument("name")
def cmd_agent_stop(name: str) -> None:
    """Stop a Manas process for this agent."""
    _require_root()
    console.print(f"\n  [bold]Stopping Manas: {escape(name)}[/bold]\n")

    # Step 1: polite terminate message
    if _manas_alive(name):
        try:
            import json as _json
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
                s.settimeout(5.0)
                s.connect(str(_manas_socket(name)))
                s.sendall(_json.dumps({"type": "terminate"}).encode() + b"\n")
                s.recv(256)
            deadline = time.monotonic() + 5.0
            while time.monotonic() < deadline:
                if not _manas_alive(name):
                    console.print(f"  [green]✓ Manas stopped gracefully[/green]")
                    console.print()
                    return
                time.sleep(0.2)
        except (OSError, socket.timeout):
            pass

    # Step 2: SIGTERM via pid file
    pid_path = Path("/var/aurelia/run") / name / "manas.pid"
    pid = None
    if pid_path.exists():
        try:
            pid = int(pid_path.read_text().strip())
        except (ValueError, OSError):
            pass

    if pid and _pid_alive(pid):
        try:
            os.kill(pid, signal.SIGTERM)
            deadline = time.monotonic() + 5.0
            while time.monotonic() < deadline:
                if not _pid_alive(pid):
                    console.print(f"  [green]✓ Manas stopped (SIGTERM)[/green]")
                    console.print()
                    return
                time.sleep(0.2)
            # Step 3: SIGKILL
            os.kill(pid, signal.SIGKILL)
            console.print(f"  [yellow]~ Manas killed (SIGKILL)[/yellow]")
        except OSError as e:
            console.print(f"  [red]✗ Failed to stop Manas:[/red] {e}")
    else:
        console.print(f"  [dim]Manas was not running[/dim]")

    console.print()


