# ── aurelia status ─────────────────────────────────────────────────────────────

@cli.command("status")
@click.option("--once", is_flag=True, help="Print once and exit (no auto-refresh).")
def cmd_status(once: bool) -> None:
    """Live dashboard — auto-refreshes every 3 seconds."""

    def _fetch_agents() -> list[dict]:
        ok, data = _socket_call({"type": "list_agents"})
        if not ok or not isinstance(data, list):
            return []
        return data

    def _render():
        return _build_status_layout(_fetch_agents())

    if once:
        runtime_pid = _read_pid("runtime")
        runtime_up = _runtime_ok()
        http_up = _http_ok()
        http_pid = _read_pid("http") or (http_up and _discover_http_pid()) or None
        print(f"runtime: {'up' if runtime_up else 'down'} (pid={runtime_pid or '—'})")
        print(f"http:    {'up' if http_up else 'down'} (pid={http_pid or '—'})")
        ok, agents = _socket_call({"type": "list_agents"})
        if ok and isinstance(agents, list):
            for a in agents:
                pid_path = Path("/var/aurelia/run") / a["name"] / "manas.pid"
                manas_pid = pid_path.read_text().strip() if pid_path.exists() else "—"
                print(f"  {a['name']}: {a.get('status', '?')} manas={manas_pid} inc={a.get('incarnation') or '—'} cycle={a.get('cycle') or '—'}")
        return

    try:
        with Live(
            _render(),
            refresh_per_second=1,
            screen=False,
            console=console,
        ) as live:
            while True:
                time.sleep(3)
                live.update(_render())
    except KeyboardInterrupt:
        pass


# ── aurelia start ─────────────────────────────────────────────────────────────

@cli.command("start")
@click.option("--http", "with_http", is_flag=True, help="Also start HTTP transport.")
def cmd_start(with_http: bool) -> None:
    """Start the runtime daemon (and optionally HTTP transport)."""
    _require_root()
    console.print("\n  [bold]Starting Aurelia...[/bold]\n")
    PIDS_DIR.mkdir(parents=True, exist_ok=True)
    env = _load_env()

    # ── Runtime daemon ────────────────────────────────────────────────────────
    if _runtime_ok():
        runtime_pid = _read_pid("runtime")
        console.print(f"  [dim]Runtime daemon already running (pid={runtime_pid})[/dim]")
    else:
        LOGS_DIR.mkdir(parents=True, exist_ok=True)
        from datetime import datetime
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        daemon_log = LOGS_DIR / f"runtime-{ts}.log"
        try:
            log_file = open(daemon_log, "a")
            site_packages = "/opt/aurelia/.venv/lib/python3.11/site-packages"
            os.environ["PYTHONPATH"] = f"{site_packages}:{PROJECT_ROOT}"
            for k in ("ANTHROPIC_API_KEY", "DISCORD_TOKEN", "OPENROUTER_API_KEY"):
                if env.get(k):
                    os.environ[k] = env[k]
            preserve = "PYTHONPATH,ANTHROPIC_API_KEY,DISCORD_TOKEN,OPENROUTER_API_KEY"
            proc = subprocess.Popen(
                ["sudo", "-u", "aurelia", f"--preserve-env={preserve}",
                 "/opt/aurelia/.venv/bin/python3", "-m", "src.samsara.runtime_daemon"],
                cwd=str(PROJECT_ROOT),
                stdout=log_file,
                stderr=log_file,
                start_new_session=True,
            )
            # proc.pid is the sudo wrapper; the actual runtime PID is its child.
            # We write a placeholder and update it after the socket is live.
            (PIDS_DIR / "runtime.pid").write_text(str(proc.pid))
        except Exception as e:
            console.print(f"  [red]✗ Failed to start runtime daemon:[/red] {e}\n")
            return

        console.print("  [dim]Waiting for runtime socket...[/dim]", end="")
        deadline = time.monotonic() + 10.0
        while time.monotonic() < deadline:
            if SOCKET_PATH.exists() and _runtime_ok():
                break
            time.sleep(0.3)
        else:
            console.print()
            console.print("  [red]✗ Timed out waiting for runtime socket[/red]")
            if daemon_log.exists():
                tail = daemon_log.read_text().strip().splitlines()[-20:]
                console.print(f"\n  [dim]── {daemon_log} (last {len(tail)} lines) ──[/dim]")
                for line in tail:
                    console.print(f"  [red]{line}[/red]")
            console.print()
            return
        # Parse the real runtime PID from the daemon log and update the PID file.
        import re as _re
        runtime_pid = proc.pid
        try:
            for line in daemon_log.read_text().splitlines():
                m = _re.search(r"\[runtime_daemon\] Starting \(pid=(\d+)", line)
                if m:
                    runtime_pid = int(m.group(1))
                    (PIDS_DIR / "runtime.pid").write_text(str(runtime_pid))
                    break
        except OSError:
            pass
        console.print(f"\r  [green]✓ Runtime is live (pid={runtime_pid})[/green]          ")

    # ── HTTP transport (optional) ─────────────────────────────────────────────
    if with_http:
        _start_http(env)

    console.print()


def _start_http(env: dict | None = None) -> None:
    """Launch the HTTP transport, waiting up to 5s for it to come up."""
    if env is None:
        env = _load_env()

    if _http_ok():
        http_pid = _read_pid("http")
        console.print(f"  [dim]HTTP transport already running (pid={http_pid})[/dim]")
        return

    try:
        proc = subprocess.Popen(
            [
                sys.executable, "-m", "uvicorn",
                "src.transport.http:app",
                "--host", "0.0.0.0",
                "--port", "8000",
            ],
            cwd=str(PROJECT_ROOT),
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        (PIDS_DIR / "http.pid").write_text(str(proc.pid))
    except Exception as e:
        console.print(f"  [red]✗ Failed to start HTTP transport:[/red] {e}")
        return

    console.print("  [dim]Waiting for HTTP transport...[/dim]", end="", flush=True)
    deadline = time.monotonic() + 5.0
    while time.monotonic() < deadline:
        if _http_ok():
            break
        time.sleep(0.3)

    http_pid = _read_pid("http")
    if _http_ok():
        console.print(f"\r  [green]✓ HTTP transport is live (pid={http_pid})[/green]          ")
    else:
        console.print(f"\r  [yellow]~ HTTP transport started (pid={http_pid}) but not yet responding[/yellow]")


# ── aurelia stop ──────────────────────────────────────────────────────────────

@cli.command("stop")
@click.option("--http", "http_only", is_flag=True, help="Stop HTTP transport only.")
def cmd_stop(http_only: bool) -> None:
    """Graceful shutdown of the plane (or just HTTP with --http)."""
    _require_root()
    if http_only:
        console.print("\n  [bold]Stopping HTTP transport...[/bold]\n")
    else:
        console.print("\n  [bold]Stopping Aurelia...[/bold]\n")

    def _stop_pid(name: str, label: str) -> None:
        pid = _read_pid(name)
        # Fallback: if no PID file but socket is live, find the owning process
        if not _pid_alive(pid) and name == "runtime" and SOCKET_PATH.exists():
            try:
                result = subprocess.run(
                    ["fuser", str(SOCKET_PATH)], capture_output=True, text=True
                )
                pids = result.stdout.strip().split()
                pid = int(pids[0]) if pids else None
            except Exception:
                pid = None
        if pid and _pid_alive(pid):
            try:
                os.kill(pid, signal.SIGTERM)
                deadline = time.monotonic() + 8.0
                while time.monotonic() < deadline:
                    if not _pid_alive(pid):
                        break
                    time.sleep(0.2)
                console.print(f"  [green]✓ {label} stopped[/green]")
            except OSError as e:
                console.print(f"  [red]✗ Failed to stop {label}:[/red] {e}")
        else:
            console.print(f"  [dim]{label} was not running[/dim]")
        pid_file = PIDS_DIR / f"{name}.pid"
        pid_file.unlink(missing_ok=True)

    if http_only:
        _stop_pid("http", "HTTP transport")
    else:
        _stop_pid("http", "HTTP transport")
        _stop_pid("runtime", "Runtime daemon")
        console.print("  [dim]Plane offline.[/dim]")

    console.print()


