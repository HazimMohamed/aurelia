def cmd_message(agent: str, text: tuple[str, ...]) -> None:
    """Send a message to an agent and show the response."""
    if not _require_runtime():
        return

    msg = " ".join(text)

    # Get active incarnation
    ok, active_data = _socket_call({"type": "get_active", "agent": agent})
    active_name: str | None = None
    if ok and isinstance(active_data, dict):
        active_name = active_data.get("active")

    # Spawn if needed
    if not active_name:
        ok2, spawn_data = _socket_call({"type": "spawn", "agent": agent})
        if ok2 and isinstance(spawn_data, dict):
            active_name = spawn_data.get("name")
        else:
            console.print(f"  [red]✗ Could not get/spawn incarnation:[/red] {spawn_data}\n")
            return

    if not active_name:
        console.print(f"  [red]✗ No active incarnation for {escape(agent)}[/red]\n")
        return

    # Get cycle from list_agents
    ok3, agents_data = _socket_call({"type": "list_agents"})
    cycle: int | None = None
    if ok3 and isinstance(agents_data, list):
        for a in agents_data:
            if a.get("name") == agent:
                cycle = a.get("cycle")

    # Dispatch
    ok4, resp_data = _socket_call({
        "type": "dispatch",
        "agent": agent,
        "incarnation": active_name,
        "hook": "human_message",
        "payload": {"content": msg, "sender": "god-lite"},
    })

    console.print()
    # Header line: ✦ agent · incarnation · cycle N
    header = Text()
    header.append("  \u2726 ", style="bold yellow")
    header.append(escape(agent), style="bold white")
    header.append(f" · {escape(active_name)}", style="dim")
    if cycle is not None:
        new_cycle = resp_data.get("cycle", cycle) if isinstance(resp_data, dict) else cycle
        header.append(f" · cycle {new_cycle}", style="dim")
    console.print(header)
    console.print(f"  [dim]{'─' * 46}[/dim]")

    if not ok4:
        console.print(f"  [red]✗ Error:[/red] {resp_data}\n")
        return

    if isinstance(resp_data, dict):
        content = resp_data.get("content", "")
        if content:
            # Render as markdown with an indent
            md = Markdown(content)
            console.print("  ", end="")
            console.print(md)
        else:
            console.print("  [dim](empty response)[/dim]")
    else:
        console.print(f"  [dim]{resp_data}[/dim]")
    console.print()


