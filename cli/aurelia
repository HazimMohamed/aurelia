@click.argument("agent")
@click.argument("incarnation", required=False, default=None)
def cmd_history(agent: str, incarnation: str | None) -> None:
    """List incarnations, or pretty-print a specific incarnation's transcript."""
    if not _require_runtime():
        return

    if incarnation is None:
        # List all incarnations
        ok, data = _socket_call({"type": "list_incarnations", "agent": agent})
        if not ok:
            console.print(f"  [red]✗ Error:[/red] {data}\n")
            return

        if not isinstance(data, list) or not data:
            console.print(f"\n  [dim]No incarnations found for {escape(agent)}[/dim]\n")
            return

        console.print(f"\n  [bold]Incarnations — {escape(agent)}[/bold]\n")
        for inc in data:
            status = inc.get("status", "unknown")
            name = inc.get("name", "unknown")
            cycle = inc.get("cycle")
            last = inc.get("last_active")

            cycle_str = f"cycle {cycle}" if cycle is not None else ""
            last_str = _relative_time(last)

            if status == "active":
                bullet = Text("● ", style="bold green")
                name_text = Text(name, style="bold green")
                status_text = Text("active", style="bold green")
            elif status == "dissolved":
                bullet = Text("○ ", style="dim")
                name_text = Text(name, style="dim")
                status_text = Text("dissolved", style="dim")
            else:
                bullet = Text("○ ", style="dim")
                name_text = Text(name, style="dim")
                status_text = Text(status, style="dim")

            line = Text("  ")
            line.append_text(bullet)
            line.append_text(name_text)
            line.append(f"   {status}   ", style="dim")
            line.append(f"{cycle_str}   ", style="dim")
            line.append(last_str, style="dim")
            console.print(line)

        console.print()
        return

    # Pretty-print transcript
    ok, data = _socket_call({
        "type": "get_history",
        "agent": agent,
        "incarnation": incarnation,
    })
    if not ok:
        console.print(f"  [red]✗ Error:[/red] {data}\n")
        return

    if not isinstance(data, list):
        console.print("  [dim]No transcript data[/dim]\n")
        return

    sep = "─" * 60
    console.print(f"\n  [bold]{escape(agent)}[/bold] / [dim]{escape(incarnation)}[/dim]\n")
    console.print(f"  [dim]{sep}[/dim]")
    _print_transcript_entries(data)
    console.print(f"\n  [dim]({len(data)} entries)[/dim]\n")


# ── Transcript rendering ───────────────────────────────────────────────────────

_ENTRY_COLORS = {
    "human_message": "bold cyan",
    "assistant_message": "white",
    "tool_call": "dim blue",
    "tool_result": "dim",
    "incarnation_start": "bold magenta",
    "bardo_complete": "bold green",
    "memory_flag": "yellow",
    "agent_note": "dim green",
    "episodic_summary": "blue",
    "undissolved": "dim magenta",
    "bardo_insight": "green",
}

_ENTRY_LABELS = {
    "human_message": "Human",
    "assistant_message": "Agent",
    "incarnation_start": "--- Incarnation Start ---",
    "bardo_complete": "--- Bardo Complete ---",
    "episodic_summary": "--- Episodic Summary ---",
    "memory_flag": "Memory Flag",
    "agent_note": "Agent Note",
    "tool_call": "Tool Call",
    "tool_result": "Tool Result",
    "invitation_response": "Invitation Response",
    "undissolved": "--- Undissolved ---",
    "bardo_insight": "Bardo Insight",
}

SEP = "─" * 60


def _print_transcript_entries(entries: list[dict], indent: str = "  ") -> None:
    """Render a list of transcript entry dicts to console."""
    for entry in entries:
        if isinstance(entry, dict):
            entry_dict = entry
        else:
            # TranscriptEntry dataclass
            entry_dict = entry.__dict__ if hasattr(entry, "__dict__") else {}

        entry_type = entry_dict.get("type", "unknown")
        ts = entry_dict.get("ts", "")
        cycle = entry_dict.get("cycle", "")
        content = entry_dict.get("content") or ""
        extra = {k: v for k, v in entry_dict.items() if k not in {"ts", "type", "content", "cycle"}}

        label = _ENTRY_LABELS.get(entry_type, entry_type)
        color = _ENTRY_COLORS.get(entry_type, "white")

        header_parts = [f"{indent}[{color}]{escape(label)}[/{color}]"]
        if ts:
            header_parts.append(f"[dim]{escape(str(ts))}[/dim]")
        if cycle:
            header_parts.append(f"[dim]cycle {cycle}[/dim]")
        console.print("  ".join(header_parts))

        if entry_type == "tool_call":
            tool_name = extra.get("tool_name", "")
            tool_input = extra.get("tool_input", {})
            console.print(f"{indent}  Tool: [dim blue]{escape(str(tool_name))}[/dim blue]")
            if tool_input:
                try:
                    inp = json.dumps(tool_input, indent=2)
                    if len(inp) > 300:
                        inp = inp[:300] + "\n    [... truncated ...]"
                    for line in inp.splitlines():
                        console.print(f"{indent}  [dim]{escape(line)}[/dim]")
                except Exception:
                    pass
        elif entry_type == "tool_result":
            result = extra.get("result", "")
            result_str = json.dumps(result, indent=2) if isinstance(result, (dict, list)) else str(result)
            if len(result_str) > 300:
                result_str = result_str[:300] + "\n    [... truncated ...]"
            for line in result_str.splitlines():
                console.print(f"{indent}  [dim]{escape(line)}[/dim]")
        elif content:
            preview = content[:600] + (" ..." if len(content) > 600 else "")
            console.print(f"\n{indent}[dim]{escape(preview)}[/dim]\n")

        console.print(f"{indent}[dim]{SEP}[/dim]")


# ── aurelia logs ──────────────────────────────────────────────────────────────

@cli.command("logs")
@click.argument("target")
@click.option("-n", "--lines", default=50, help="Number of initial tail lines.")
def cmd_logs(target: str, lines: int) -> None:
    """Tail logs. TARGET is 'runtime', 'http', or an agent name."""

    if target in ("runtime", "http"):
        log_file = LOGS_DIR / f"{target}.log"
        if not log_file.exists():
            console.print(f"\n  [red]Log file not found:[/red] {log_file}\n")
            return
        source_color = "cyan" if target == "runtime" else "magenta"
        console.print(f"\n  [bold]Tailing {target} log[/bold] [dim]{log_file}[/dim]\n")
        try:
            proc = subprocess.Popen(
                ["tail", "-f", "-n", str(lines), str(log_file)],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
            )
            assert proc.stdout is not None
            for line in proc.stdout:
                line = line.rstrip()
                low = line.lower()
                if "error" in low or "exception" in low or "traceback" in low:
                    console.print(Text(line, style="bold red"))
                elif "warn" in low:
                    console.print(Text(line, style="yellow"))
                else:
                    console.print(Text(line, style=source_color))
        except KeyboardInterrupt:
            pass
        return

    # Agent transcript live-follow
    agent = target
    agent_home = Path("/home") / agent
    if not agent_home.exists():
        console.print(f"\n  [red]Agent home not found:[/red] {agent_home}\n")
        return

    # Resolve transcript path: prefer karma/current, fall back to akasha latest
    transcript_path: Path | None = None
    karma_current = agent_home / "karma" / "current"
    if karma_current.exists() or karma_current.is_symlink():
        try:
            active_dir = karma_current.resolve()
            candidate = active_dir / "transcript.jsonl"
            if candidate.exists():
                transcript_path = candidate
        except OSError:
            pass

    if transcript_path is None:
        # Find most recently modified transcript in akasha
        akasha = agent_home / "akasha"
        if akasha.exists():
            candidates = sorted(
                akasha.rglob("*transcript.jsonl"),
                key=lambda p: p.stat().st_mtime,
                reverse=True,
            )
            if candidates:
                transcript_path = candidates[0]

    if transcript_path is None:
        console.print(f"\n  [red]No transcript found for agent:[/red] {agent}\n")
        return

    console.print(f"\n  [bold]Live transcript for {escape(agent)}[/bold] [dim]{transcript_path}[/dim]\n")

    # Print last N lines then live-follow
    raw_lines = transcript_path.read_text(encoding="utf-8").splitlines()
    recent = raw_lines[-lines:] if len(raw_lines) > lines else raw_lines
    _print_jsonl_lines(recent)

    # Live follow
    try:
        with transcript_path.open("r", encoding="utf-8") as f:
            f.seek(0, 2)  # seek to end
            while True:
                line = f.readline()
                if not line:
                    time.sleep(0.5)
                    continue
                line = line.strip()
                if line:
                    _print_jsonl_lines([line])
    except KeyboardInterrupt:
        pass


def _print_jsonl_lines(raw_lines: list[str]) -> None:
    """Parse and pretty-print JSONL transcript lines."""
    sep = "─" * 60
    for raw in raw_lines:
        raw = raw.strip()
        if not raw:
            continue
        try:
            entry = json.loads(raw)
        except json.JSONDecodeError:
            continue

        entry_type = entry.get("type", "unknown")
        ts = entry.get("ts", "")
        cycle = entry.get("cycle", "")
        content = entry.get("content", "")
        label = _ENTRY_LABELS.get(entry_type, entry_type)
        color = _ENTRY_COLORS.get(entry_type, "white")

        header_parts = [f"  [{color}]{escape(label)}[/{color}]"]
        if ts:
            header_parts.append(f"[dim]{escape(ts)}[/dim]")
        if cycle:
            header_parts.append(f"[dim]cycle {cycle}[/dim]")
        console.print("  ".join(header_parts))

        if content:
            preview = content[:400] + (" ..." if len(content) > 400 else "")
            console.print(f"  [dim]{escape(preview)}[/dim]")

        console.print(f"  [dim]{sep}[/dim]")


